{
  "info": {
    "name": "Construction Management API",
    "description": "Complete API collection for Users, Projects, and Daily Progress Reports",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token — auto-filled after login"
    },
    {
      "key": "projectId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me" }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Highway Construction Phase 1\",\n  \"description\": \"Building 10km highway stretch from A to B\",\n  \"startDate\": \"2026-01-15\",\n  \"endDate\": \"2026-12-31\",\n  \"budget\": 5000000.00,\n  \"location\": \"Pune, Maharashtra\"\n}"
            }
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/projects?status=active&limit=10&offset=0",
              "query": [
                { "key": "status", "value": "active", "description": "planned | active | completed" },
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}" }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\",\n  \"description\": \"Updated project description\"\n}"
            }
          }
        },
        {
          "name": "Delete Project (Admin only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}" }
          }
        }
      ]
    },
    {
      "name": "Daily Progress Reports (DPR)",
      "item": [
        {
          "name": "Create DPR",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/dpr" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-03-13\",\n  \"work_description\": \"Completed foundation laying for section A. Concrete pouring done for 200 meters.\",\n  \"weather\": \"Sunny, 28°C\",\n  \"worker_count\": 45\n}"
            }
          }
        },
        {
          "name": "Get All DPRs for Project",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/dpr",
              "query": [
                { "key": "date", "value": "2026-03-13", "disabled": true, "description": "Optional: filter by date YYYY-MM-DD" }
              ]
            }
          }
        }
      ]
    }
  ]
}
